__pycache__/
*.pyc
.venv/
venv/
.idea/

# Runtime state — содержит секреты и локальные данные
config.json
state.json
watch.log
watch.log.*
cookie_helper.log

# Persönal runtime data (Steam wishlist / purchases / watchlists) — не публикуем
gamelist.json
gameblacklist.json
purchases.json
salelist.json
watchlist.json

# Шаблоны конфигов — коммитим
!config.example.json

# Internal docs — не для публичного репо
CLAUDE.md
DESIGN.md

# Артефакты сборки инсталлятора (.gitignore НЕ поддерживает inline-#
# комментарии — комментарий должен быть на отдельной строке, иначе
# пробелы+комментарий становятся частью паттерна и он не матчит).
# installer/python/  — скачанный bundled Python (~27 МБ)
# installer/dist/    — собранные Setup .exe
# installer/*.exe    — любые собранные .exe в корне installer
# preview/           — скриншоты и dev-утилиты, не для публикации
installer/python/
installer/dist/
installer/*.exe
preview/
